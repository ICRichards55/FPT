const DATA_FILENAME = 'fpt_live_data.json';

// ── STORAGE ──────────────────────────────────────────────────────
function getDataFile_() {
  const files = DriveApp.getRootFolder().getFilesByName(DATA_FILENAME);
  if (files.hasNext()) return files.next();
  const empty = JSON.stringify({athletes:[],profiles:{},entries:[],achievements:[]});
  return DriveApp.getRootFolder().createFile(DATA_FILENAME, empty, MimeType.PLAIN_TEXT);
}

function readState_() {
  try {
    return JSON.parse(getDataFile_().getBlob().getDataAsString());
  } catch(e) {
    return { athletes:[], profiles:{}, entries:[], achievements:[] };
  }
}
function readState_() {
  try {
    return JSON.parse(getDataFile_().getBlob().getDataAsString());
  } catch(e) {
    return { athletes:[], profiles:{}, entries:[], achievements:[] };
  }
}

function writeState_(state) {
  getDataFile_().setContent(JSON.stringify(state));
}

 

// ── MERGE ─────────────────────────────────────────────────────────
// FIX: athletes are always stored as plain strings.
// The bug was that current.athletes.includes(name) returns false when the
// existing array contains objects {name,gender} — so the string version
// gets pushed alongside the object, creating duplicates.
// Now we normalise to strings first, then compare by name.
function mergeBatch_(batch) {
  const current = readState_();
  if (!current.athletes)    current.athletes    = [];
  if (!current.profiles)    current.profiles    = {};
  if (!current.entries)     current.entries     = [];
  if (!current.achievements) current.achievements = [];

  // Normalise existing athletes array → plain strings, deduplicated
  const seen = new Set();
  current.athletes = current.athletes
    .map(function(a) { return (typeof a === 'object' && a !== null) ? a.name : a; })
    .filter(function(name) {
      if (!name || seen.has(name)) return false;
      seen.add(name);
      return true;
    });

  // Merge incoming athletes — always push plain strings
  (batch.athletes || []).forEach(function(a) {
    const name   = (typeof a === 'object' && a !== null) ? a.name   : a;
    const gender = (typeof a === 'object' && a !== null) ? a.gender : null;
    if (!name) return;
    if (!seen.has(name)) {
      seen.add(name);
      current.athletes.push(name);   // ← always a plain string
    }
    // Gender lives in profiles, not in the athletes array
    if (!current.profiles[name]) current.profiles[name] = {};
    if (gender && !current.profiles[name].gender) {
      current.profiles[name].gender = gender;
    }
  });

  // Merge profiles (non-destructive)
  Object.entries(batch.profiles || {}).forEach(function([name, profile]) {
    if (!current.profiles[name]) {
      current.profiles[name] = profile;
    } else {
      Object.keys(profile).forEach(function(k) {
        if (profile[k] !== '' && profile[k] != null && !current.profiles[name][k]) {
          current.profiles[name][k] = profile[k];
        }
      });
    }
  });

  // Deduplicate entries by ID
  const seenIds = new Set(current.entries.map(function(e) { return e.id; }));
  let added = 0;
  (batch.entries || []).forEach(function(entry) {
    if (!seenIds.has(entry.id)) {
      current.entries.push(entry);
      seenIds.add(entry.id);
      added++;
    }
  });

  writeState_(current);
  return '✓ Imported ' + added + ' new entries. Athletes: ' + current.athletes.length + '. Total entries now: ' + current.entries.length;
}

