// Clears the database and re-imports batch 1 from scratch
function resetAndImportBatch1() {
  const state = readState_();
  state.entries = [];
  state.athletes = [];
  state.profiles = {};
  writeState_(state);
  Logger.log('Database cleared. Re-importing batch 1...');
  return importBatch1();
}

// ── UTILITIES ─────────────────────────────────────────────────────
function initStorage() {
  getDataFile_();
  Logger.log('Storage initialized: ' + DATA_FILENAME + ' ready in My Drive');
}

function getStats() {
  const state = readState_();
  const hasObjects = (state.athletes || []).some(a => typeof a === 'object');
  Logger.log('Athletes : ' + (state.athletes || []).length + (hasObjects ? ' ⚠️ contains objects — run fixAthletes()' : ' ✓ clean'));
  Logger.log('Entries  : ' + (state.entries || []).length);
  Logger.log('Profiles : ' + Object.keys(state.profiles || {}).length);
  Logger.log('Achievements: ' + (state.achievements || []).length);
  (state.athletes || []).forEach(function(a) {
    const name = (typeof a === 'object') ? a.name : a;
    const count = (state.entries || []).filter(e => e.athlete === name).length;
    Logger.log('  ' + name + ': ' + count + ' entries');
  });
}

// One-time repair: normalises athletes array and seeds gender in profiles
function fixAthletes() {
  const genderMap = {
    'Brayden Bobitski':'male','Caleb Anderson':'male','Jaxon Anderson':'male',
    'Jayden Bittner':'male','Nate Astor':'male','Roman Angle':'male','Zach Bardz':'male',
    'Jacob Bostian':'male','Andrew Bredel':'male','Matthew Bredel':'male',
    'Nathan Brown':'male','Maddox Colbert':'male','Frankie Cali':'male',
    'Geno Calgaro':'male','Rocco Cosentino':'male','Mason Chambers':'male',
    'Jackson Crow':'male'
  };
  const state = readState_();
  const seen = new Set();
  state.athletes = (state.athletes || [])
    .map(a => (typeof a === 'object' && a !== null) ? a.name : a)
    .filter(name => { if (!name || seen.has(name)) return false; seen.add(name); return true; });
  if (!state.profiles) state.profiles = {};
  Object.keys(genderMap).forEach(function(name) {
    if (!state.profiles[name]) state.profiles[name] = {};
    if (!state.profiles[name].gender) state.profiles[name].gender = genderMap[name];
  });
  writeState_(state);
  Logger.log('Fixed. Athletes: ' + state.athletes.length + ' | Profiles: ' + Object.keys(state.profiles).length + ' | Entries: ' + state.entries.length);
}

// Removes all Jayden Bittner entries (run before re-importing corrected data)
function purgeBittner() {
  const state = readState_();
  const before = state.entries.length;
  state.entries = state.entries.filter(e => e.athlete !== 'Jayden Bittner');
  writeState_(state);
  Logger.log('purgeBittner: removed ' + (before - state.entries.length) + ' entries. Remaining: ' + state.entries.length);
}

