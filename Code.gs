function fixDataErrors() {
  var state = readState_();
  var fixed = 0;

  state.entries = state.entries.map(function(e) {

    // Zack Schrockmon 6/24/2025 — all 1.0 fly → 1.10
    if (e.athlete === 'Zack Schrockmon' && e.date === '2025-06-24' && e.exercise === 'fly' && e.value === 1) {
      e.value = 1.10; fixed++;
    }

    // Zack Schrockmon 7/24/2025 — 1.0 fly → 1.10
    if (e.athlete === 'Zack Schrockmon' && e.date === '2025-07-24' && e.exercise === 'fly' && e.value === 1) {
      e.value = 1.10; fixed++;
    }

    // Jayden Bittner 2026-05-23 → 2025-05-23
    if (e.athlete === 'Jayden Bittner' && e.date === '2026-05-23') {
      e.date = '2025-05-23'; fixed++;
    }

    return e;
  });

  writeState_(state);
  Logger.log('Fixed ' + fixed + ' entries.');
}
function fixPendingIntakes() {
  var state = readState_();
  // Keep only unique by submittedAt
  var seen = {};
  state.pendingIntakes = (state.pendingIntakes || []).filter(function(p) {
    var key = p.submittedAt + p.firstName + p.lastName;
    if (seen[key]) return false;
    seen[key] = true;
    return true;
  });
  writeState_(state);
  Logger.log('Pending intakes after dedup: ' + state.pendingIntakes.length);
}
